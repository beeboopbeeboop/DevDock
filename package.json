{
  "name": "devdock",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "devdock": "./src/cli.ts"
  },
  "scripts": {
    "dev": "concurrently \"bun run dev:server\" \"bunx tauri dev\"",
    "dev:server": "bun run --watch src/server/index.ts",
    "dev:client": "vite",
    "build": "vite build",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "start": "open -a DevDock",
    "start:server": "bun run src/server/index.ts",
    "menubar": "sleep 2 && open ./menubar/DevDock\\ MenuBar.app",
    "menubar:build": "cd menubar && ./build-app.sh",
    "cli": "bun run src/cli.ts",
    "setup": "bun run src/setup.ts"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.90.21",
    "@tauri-apps/api": "^2",
    "concurrently": "^9.2.1",
    "hono": "^4.12.8",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@tauri-apps/cli": "^2",
    "@types/bun": "^1.3.10",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vite": "^8.0.0"
  }
}
