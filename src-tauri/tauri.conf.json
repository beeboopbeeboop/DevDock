{
  "$schema": "https://raw.githubusercontent.com/nicktomlin/tauri-schema/refs/heads/main/tauri.conf.schema.json",
  "productName": "DevDock",
  "version": "0.1.0",
  "identifier": "com.devdock.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:3070",
    "beforeDevCommand": "",
    "beforeBuildCommand": "bun run build"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "DevDock",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 500,
        "visible": false,
        "decorations": true,
        "transparent": false
      }
    ],
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "tooltip": "DevDock"
    },
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://localhost:3070 http://127.0.0.1:3070; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: asset: http://localhost:*; script-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "13.0"
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
